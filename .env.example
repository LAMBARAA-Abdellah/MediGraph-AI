# MediGraph AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=MediGraph AI
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# OpenAI Compatible LLM
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Database
DATABASE_URL=sqlite:///./data/medigraph.db

# Redis (optional)
REDIS_URL=redis://redis:6379/0
USE_REDIS=false

# MCP Server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8100
MCP_SERVER_URL=http://mcp-server:8100

# LangGraph
LANGGRAPH_CHECKPOINT_DIR=./data/checkpoints

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/medigraph.log

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security
SECRET_KEY=change-this-to-a-secure-random-key

# Disclaimer (mandatory)
MEDICAL_DISCLAIMER=This system does not replace a professional medical consultation.
